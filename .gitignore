# Local .terraform directory
.terraform/

# Ignore all .tfstate, .tfstate.backup, and .tfstate.d files
*.tfstate
*.tfstate.*
*.tfstate.backup
.terraform.tfstate.lock.info

# Ignore tfvars files that might contain secrets or environment-specific overrides
# Commit only safe default tfvars (e.g., terraform.tfvars.example)
*.tfvars
*.tfvars.json

# Crash log files
crash.log
crash.*.log

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore plan files
*.tfplan

# IDE and Editor files
.idea/
.vscode/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
